# =========================
# BANCO (usado no compose e backend)
# =========================
POSTGRES_USER=romaneio_app
POSTGRES_PASSWORD=COLOQUE_UMA_SENHA_FORTE_AQUI
POSTGRES_DB=romaneio_rapido
POSTGRES_SERVER=db
POSTGRES_PORT=5432

# =========================
# APP / JWT
# =========================
SECRET_KEY=COLOQUE_UM_TOKEN_GIGANTE_E_ALEATORIO_AQUI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =========================
# AMBIENTE / SEGURANÇA
# =========================
ENVIRONMENT=production
ALLOWED_HOSTS=romaneiorapido.com.br,www.romaneiorapido.com.br
MAX_BODY_SIZE_BYTES=10485760

# =========================
# CORS (frontend oficial)
# =========================
CORS_ORIGINS=https://romaneiorapido.com.br,https://www.romaneiorapido.com.br

# =========================
# ADMIN INICIAL (seed)
# =========================
PGADMIN_DEFAULT_EMAIL=admin@romaneiorapido.com.br
PGADMIN_DEFAULT_PASSWORD=COLOQUE_SENHA_FORTE_ADMIN_AQUI

#TODO: Tem que adicionar isso aqui Wallace
# =========================
# E-MAIL (opcional, reset de senha)
# =========================
SMTP_HOST=smtp.seudominio.com
SMTP_PORT=587
SMTP_USER=no-reply@romaneiorapido.com.br
SMTP_PASS=COLOQUE_SENHA_SMTP_AQUI
SMTP_FROM=no-reply@romaneiorapido.com.br
FRONTEND_URL=https://romaneiorapido.com.br

# =========================
# PORTA EXPOSTA DO FRONTEND NO HOST
# (se tiver nginx do host, prefira 127.0.0.1:8082:80 no compose)
# =========================
PORT_FRONTEND=80